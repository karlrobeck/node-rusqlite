{
  "tasks": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform -o bindings --js binding.js --esm --dts binding.d.ts",
    "format": "deno run -A npm:prettier . -w",
    "lint": "deno lint",
    "test": "deno test tests/*.test.ts",
    "bench": "deno bench benchmark/*.bench.ts",
    "bench:crud": "deno bench benchmark/basic-crud.bench.ts",
    "bench:prepared": "deno bench benchmark/prepared-statements.bench.ts",
    "bench:transactions": "deno bench benchmark/transactions.bench.ts",
    "bench:bulk": "deno bench benchmark/bulk-operations.bench.ts",
    "bench:connmodes": "deno bench benchmark/connection-modes.bench.ts",
    "bench:concurrent": "deno bench benchmark/concurrent.bench.ts",
    "bench:viz": "deno run -A benchmark/visualize-runner.ts --open",
    "visualize": "deno run -A benchmark/visualize.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/expect": "jsr:@std/expect@^1.0.18"
  }
}
