{
  "name": "@karlrobeck/node-rusqlite",
  "version": "0.1.0",
  "description": "Type-safe SQLite for Node.js, powered by Rust rusqlite crate and napi-rs. Zero external dependencies, native performance, perfect for desktop apps, Electron, and embedded systems.",
  "author": {
    "name": "Karl Robeck Alferez",
    "email": "karlalferezfx@gmail.com",
    "url": "https://github.com/karlrobeck"
  },
  "license": "MIT",
  "homepage": "https://github.com/karlrobeck/node-rusqlite",
  "repository": {
    "type": "git",
    "url": "https://github.com/karlrobeck/node-rusqlite"
  },
  "bugs": {
    "url": "https://github.com/karlrobeck/node-rusqlite/issues"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/karlrobeck"
    }
  ],
  "main": "index.js",
  "keywords": [
    "napi-rs",
    "NAPI",
    "N-API",
    "Rust",
    "node-addon",
    "node-addon-api"
  ],
  "files": [
    "./bindings/binding.d.ts",
    "./bindings/binding.js"
  ],
  "napi": {
    "binaryName": "node-rusqlite",
    "targets": [
      "x86_64-pc-windows-msvc",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-apple-darwin"
    ],
    "constEnum": false
  },
  "engines": {
    "node": ">= 12.22.0 < 13 || >= 14.17.0 < 15 || >= 15.12.0 < 16 || >= 16.0.0"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "bench": "node --import @oxc-node/core/register benchmark/bench.ts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform -o bindings --js binding.js --esm --dts binding.d.ts"
  },
  "devDependencies": {
    "@emnapi/core": "^1.5.0",
    "@emnapi/runtime": "^1.5.0",
    "@napi-rs/cli": "^3.2.0",
    "@oxc-node/core": "^0.1.0",
    "@tybys/wasm-util": "^0.10.0",
    "@types/bun": "^1.3.11",
    "@types/deno": "^2.5.0",
    "chartjs": "^0.3.24",
    "typescript": "^6.0.0"
  }
}
